{
  "version": "1.0.0",
  "nombre": "CAT_CX_MODEL",
  "descripcion": "Modelo de clasificación NLP para categorías TELCO",
  "fecha_creacion": "2024",
  "framework": {
    "nombre": "Scikit-Learn Pipeline",
    "vectorizer": "TfidfVectorizer",
    "reductor": "TruncatedSVD",
    "clasificador": "LogisticRegression"
  },
  "configuracion": {
    "tfidf_max_features": 10000,
    "tfidf_ngram_range": [1, 2],
    "tfidf_min_df": 2,
    "tfidf_max_df": 0.95,
    "svd_componentes": 100,
    "logreg_max_iter": 1000,
    "logreg_solver": "lbfgs",
    "logreg_class_weight": "balanced"
  },
  "preprocesamiento": {
    "idioma": "español",
    "lematizacion": true,
    "modelo_spacy": "es_core_news_sm",
    "stopwords": true,
    "min_longitud_token": 3
  },
  "umbrales_confianza": {
    "probabilidad_minima": 0.30,
    "margen_top1_top2": 0.15
  },
  "metricas_reporte": [
    "accuracy",
    "f1_macro",
    "f1_weighted",
    "cv_f1_macro"
  ],
  "visualizaciones": [
    "01_distribucion_categorias.png",
    "02_matriz_confusion.png",
    "03_f1_por_categoria.png",
    "04_curva_aprendizaje.png",
    "05_dashboard_metricas.png",
    "06_top_palabras_categoria.png"
  ],
  "archivos_salida": {
    "modelo": "CAT_CX_MODEL.pkl",
    "no_categorizados": "NO_CATEGORIZADOS.xlsx",
    "graficas_directorio": "GRAFICAS/"
  },
  "dependencias": {
    "requeridas": [
      "pandas>=1.3.0",
      "scikit-learn>=1.0.0",
      "joblib>=1.1.0",
      "numpy>=1.21.0",
      "openpyxl>=3.0.0",
      "matplotlib>=3.4.0",
      "seaborn>=0.11.0"
    ],
    "opcionales": [
      "spacy>=3.0.0 (lematización)",
      "imbalanced-learn>=0.8.0 (SMOTE)"
    ]
  },
  "flujo_mejora_continua": {
    "paso_1": "Revisar NO_CATEGORIZADOS.xlsx - pestaña No_Categorizados",
    "paso_2": "Completar columna 'Categoria_Correcta' en casos de baja confianza",
    "paso_3": "Incorporar filas corregidas a Data de Entrenamiento.xlsx",
    "paso_4": "Ejecutar 1_ENTRENAR_MODELO.py para reentrenar",
    "paso_5": "Comparar métricas F1-Macro nuevas vs anteriores"
  },
  "categorias_entrenadas": [],
  "n_muestras_entrenamiento": 0,
  "vocabulario_tamaño": 0,
  "notas": "Las categorías y métricas específicas se actualizan automáticamente durante el entrenamiento"
}
